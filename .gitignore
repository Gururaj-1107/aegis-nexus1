# ─────────────────────────────────────────────────────────────
#  Aegis Nexus — Root .gitignore
# ─────────────────────────────────────────────────────────────

# ── Node / npm ────────────────────────────────────────────────
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Next.js ───────────────────────────────────────────────────
**/.next/
**/out/
**/build/
**/dist/

# ── Environment variables ─────────────────────────────────────
# Keep .env.example and .env.local.example — only ignore real env files
.env
.env.local
.env.development
.env.production
.env.test
# Do NOT ignore: .env.example  .env.local.example

# ── Google Cloud SDK installer (binary, not needed in repo) ───
GoogleCloudSDKInstaller.exe

# ── Native Node addons / binaries ────────────────────────────
*.dll.node
*.node

# ── OS generated files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-workspace

# ── Build artifacts ───────────────────────────────────────────
dist/
build/
out/
coverage/
.nyc_output/

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── Prisma ────────────────────────────────────────────────────
# Keep schema.prisma and migrations — only ignore generated client
services/backend/node_modules/

# ── Docker (DO NOT exclude — keep Dockerfile and docker-compose.yml) ──
# docker-compose.yml  <-- intentionally NOT ignored
# Dockerfile          <-- intentionally NOT ignored

# ── Misc ─────────────────────────────────────────────────────
*.zip
*.tar.gz
zip_project.js
.cache/
tmp/
temp/
