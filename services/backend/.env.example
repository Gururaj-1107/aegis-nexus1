# ─────────────────────────────────────────────────────────────
#  Aegis Nexus — Backend Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Server port
PORT=3001

# PostgreSQL connection string
# For local dev:  postgresql://postgres:YOUR_PASSWORD@localhost:5432/aegisnexus
# For production: set to your Cloud SQL public IP or use Cloud SQL Auth Proxy URL
DATABASE_URL=postgresql://USER:PASSWORD@CLOUD_SQL_IP:5432/aegisnexus

# Google Gemini API key (for AI chat, embeddings, translations)
GEMINI_API_KEY=your-gemini-api-key-here

# Google OAuth 2.0 Client ID (from GCP Credentials page)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google Cloud Project ID (run: gcloud config get-value project)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Document AI processor ID (for PDF/document parsing)
DOCUMENT_AI_PROCESSOR_ID=your-document-ai-processor-id

# Allowed CORS origin — set to your deployed frontend URL
FRONTEND_URL=https://your-frontend-cloud-run-url

# Internal URL of the C++ matcher service (used inside Docker Compose)
MATCHER_URL=http://cpp_matcher:8080
