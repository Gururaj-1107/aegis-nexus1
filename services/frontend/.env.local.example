# ─────────────────────────────────────────────────────────────
#  Aegis Nexus — Frontend Environment Variables
#  Copy this file to .env.local and fill in your actual values.
#  NEVER commit .env.local to version control.
#
#  NOTE: In production (Cloud Run), these are passed as Docker
#        --build-arg flags at build time, not as runtime env vars.
# ─────────────────────────────────────────────────────────────

# URL of the deployed backend Cloud Run service
NEXT_PUBLIC_API_URL=https://your-backend-cloud-run-url

# Google Maps JavaScript API key (enable Maps JS API in GCP Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google OAuth 2.0 Client ID (must match backend GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google Gemini API key (for client-side AI features if any)
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key
